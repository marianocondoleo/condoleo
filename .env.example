# ============================================
# CONDOLEO - Variables de Entorno
# ============================================
# Copia este archivo a .env.local y rellena los valores
#
# INSTRUCCIONES:
# 1. Copia este archivo: cp .env.example apps/web/.env.local
# 2. Rellena cada variable con tus valores reales
# 3. NO commits .env.local a git (está en .gitignore)
# ============================================

# -------- DATABASE --------
# Neon - Database PostgreSQL serverless
# Obtener en: https://neon.tech
# Formato: postgresql://user:password@host/database
DATABASE_URL=postgresql://user:password@region.neon.tech/database

# -------- CLERK - Autenticación --------
# Clerk - Authentication & User Management
# Obtener en: https://dashboard.clerk.com
# Variables públicas (se exponen al cliente):
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Variables privadas (solo servidor):
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxx

# -------- CLOUDINARY - Almacenamiento de Archivos --------
# Cloudinary - Image/File Hosting
# Obtener en: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxx

# -------- EMAIL - Resend --------
# Resend - Email service
# Obtener en: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@condoleo.com
ADMIN_EMAIL=admin@condoleo.com

# -------- RATE LIMITING - Upstash Redis --------
# Upstash - Redis KV store para rate limiting
# Obtener en: https://console.upstash.com
# Dejar en blanco para deshabilitar rate limiting en desarrollo
UPSTASH_REDIS_REST_URL=https://user-xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXXXxxxxxxxxxxxxx

# -------- ENTORNO --------
# NODE_ENV se configura automáticamente por el build tool
# No es necesario ponerlo aquí, pero se documenta:
# NODE_ENV=development | production
